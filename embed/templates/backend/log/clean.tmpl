{[template "backend/common/header_nonav.tmpl" .]}

<div class="layui-fluid">
    <div class="layui-col-md12" style="padding: 5px;">
        <div class="layui-card">
            <div class="layui-card-body">

                <div class="layui-tab layui-tab-brief">
                    <ul class="layui-tab-title" id="status">
                        {[range $menu := .submenu]}
                            <li data-status="{[$menu.Number]}" {[if eq (print "/" $.admin_path "/" $menu.Link) $.CurrentPath]}class="layui-this"{[end]}><a href="/{[$.admin_path]}/{[$menu.Link]}">{[$menu.Name]}</a></li>
                        {[end]}
                    </ul>
                </div>

                <div class="layui-form toolbar" style="margin-top: 10px;margin-bottom: 10px;">
                <form class="layui-form layui-form-pane" onclick="return false;">
                    <table class="layui-table">
                        <colgroup><col width="150"><col></colgroup>
                        <tbody>

                            <tr class="bls">
                                <td>清理方式</td>
                                <td>
                                    <input type="radio" name="clean" value="all" title="全部清除" lay-filter="clean" checked>
                                    <input type="radio" name="clean" value="day" title="按天数清除" lay-filter="clean">
                                </td>
                            </tr>

                            <tr class="bls day-row layui-hide">
                                <td>天数</td>
                                <td>
                                    <div class="layui-inline">
                                        <div class="layui-input-inline">
                                            <input type="number" name="day" autocomplete="off" class="layui-input" value="30" placeholder="">
                                        </div>
                                        <label class="layui-form-label" style="float: right;">天以外</label>
                                    </div>
                                    <br/>
                                    <p class="layui-font-12">表示清除此天数以外的日志数据。</p>
                                </td>
                            </tr>

                            <tr>
                                <td colspan="2" >
                                    <button class="layui-btn" lay-filter="submit_save" lay-submit>保存</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">

layui.config({base: '/static/layuiadmin/'}).use(['table','jquery'], function(){
///
var admin = layui.admin
,$ = layui.$
,form = layui.form
,table = layui.table;

form.on('radio(clean)', function(data){
    if (data.value === 'day') {
      document.querySelector('.day-row')?.classList.remove('layui-hide');
    } else {
      document.querySelector('.day-row')?.classList.add('layui-hide');
    }
});
///
});
</script>

{[template "backend/common/footer.tmpl" .]}
