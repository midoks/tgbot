{[template "backend/common/header_nonav.tmpl" .]}

<div class="layui-fluid">
    <div class="layui-col-md12" style="padding: 5px;">
        <div class="layui-card">
            <div class="layui-card-body">

                <div class="layui-tab layui-tab-brief">
                    <ul class="layui-tab-title" id="status">
                        {[range $menu := .submenu]}
                            <li data-status="{[$menu.Number]}" {[if eq (print "/" $.admin_path "/" $menu.Link) $.CurrentPath]}class="layui-this"{[end]}><a href="/{[$.admin_path]}/{[$menu.Link]}">{[$menu.Name]}</a></li>
                        {[end]}
                    </ul>
                </div>

                <div class="layui-form toolbar" style="margin-top: 10px;margin-bottom: 10px;">
                <form class="layui-form" action="" id="log_form" onclick="return false;">

                    <div class="layui-inline mr0">
                        <div class="layui-input-inline mr0">
                            <input name="times" id="date_range" class="layui-input date-icon" type="text" placeholder="请选择日期范围" autocomplete="off">
                        </div>
                    </div>

                    <div class="layui-inline mr0">
                        <div class="layui-input-inline mr0">
                            <input type="text" name="key" placeholder="请输入关键字" autocomplete="off" class="layui-input" value="">
                        </div>
                    </div>


                    <div class="layui-inline mr0">
                        <button class="layui-btn layui-btn-sm" id="table-sreach" data-id="list" lay-submit lay-filter="table-sreach"><i class="layui-icon">&#xe615;</i>查询
                        </button>
                    </div>
                </form>
                </div>
                <div id="list"></div>
                <div id="pager" style="text-align:center;margin-top: 10px;"></div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">

layui.config({base: '/static/layuiadmin/'}).use(['jquery','form','laydate','laypage'], function(){
///
var $ = layui.$
,form = layui.form
,laydate = layui.laydate
,laypage = layui.laypage;

// date range


function renderTable(){
    var where_data = $('#log_form').serializeArray();
    where_data = array2arr(where_data);

    table.render({
        elem: '#list',
        url: '/{[.admin_path]}/log/list',
        title: '数据表',
        cols: [[
            {field:'content', title:'内容'},
            {field:'create_time', title:'创建时间', width:185, templet: function(d){return layui.util.toDateString(d.create_time * 1000, 'yyyy-MM-dd HH:mm:ss');}},
            {title:'操作', toolbar: '#cmdTpl', width:90, fixed: 'right'}
            ]],
        where:where_data,
        page: true,
        done: function(res, curr, count){
        }
    });
}

renderTable();

// search
form.on('submit(table-sreach)', function(){
    renderTable();
    return false;
});

///
});
</script>

<script type="text/html" id="cmdTpl">
<a class="layui-btn layui-btn-danger layui-btn-xs" lay-event='delete' onclick="Admin.del(this, '/{[$.admin_path]}/log/delete','{{d.id}}')">删除</a>
</script>

{[template "backend/common/footer.tmpl" .]}
