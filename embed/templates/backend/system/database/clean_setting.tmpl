{[template "backend/common/header_nonav.tmpl" .]}

<div class="layui-fluid">
    <div class="layui-col-md12" style="padding: 5px;">
        <div class="layui-card">
            <div class="layui-card-body">

                <div class="layui-tab layui-tab-brief">
                    <ul class="layui-tab-title" id="status">
                        {[range $menu := .submenu]}
                            <li data-status="{[$menu.Number]}" {[if IsSubOrEq $.CurrentPath (print "/" $.admin_path "/" $menu.Link)]}class="layui-this"{[end]}><a href="/{[$.admin_path]}/{[$menu.Link]}">{[$menu.Name]}</a></li>
                        {[end]}
                    </ul>
                </div>


                <div class="layui-tab layui-tab-brief">
                    <ul class="layui-tab-title" id="status">
                        {[range $db_menu := .database_submenu]}
                            <li data-status="{[$db_menu.Number]}" {[if IsSubOrEq $.CurrentPath (print "/" $.admin_path "/" $db_menu.Link)]}class="layui-this"{[end]}><a href="/{[$.admin_path]}/{[$db_menu.Link]}">{[$db_menu.Name]}</a></li>
                        {[end]}
                    </ul>
                </div>


               <div class="layui-form toolbar" style="margin-top: 10px;margin-bottom: 10px;">
                <form class="layui-form layui-form-pane" onclick="return false;">
                    <table class="layui-table">
                        <colgroup><col width="150"><col></colgroup>
                            <tr>
                                <td>监控日志保留天数</td>
                                <td>
                                    <div class="layui-inline">
                                        <input type="number" name="monitor_log_days" autocomplete="off" class="layui-input" value="{[.monitor_log_days]}" placeholder="">
                                    </div>
                                    <p class="layui-font-12">超过此天数的日志将会被自动清理，至少1天。</p>
                                </td>
                            </tr>

                            <tr>
                                <td colspan="2">
                                    <button class="layui-btn" lay-filter="submit_monitor_log" lay-submit>保存</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">

layui.config({base: '/static/layuiadmin/'}).use(['table','jquery'], function(){
///
var admin = layui.admin
,$ = layui.$
,form = layui.form
,table = layui.table;

form.on("submit(submit_monitor_log)", function(data){
    var field = data.field;
    $.post("/{[$.admin_path]}/system/database/clean_setting", field, function(res) {
        showMsg(res.msg, function(){
            if(res.code > -1){
                parent.location.reload();
            }
        },{icon: res.code > -1 ? 1 : 2,shift:res.code>-1 ? 0 : 6});
    },'json');
    return false;
});

///
});
</script>

{[template "backend/common/footer.tmpl" .]}