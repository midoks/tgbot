{[template "backend/common/header_nonav.tmpl" .]}

<div class="layui-fluid">
    <div class="layui-col-md12" style="padding: 5px;">
        <div class="layui-card">
            <div class="layui-card-body">

                <div class="layui-tab layui-tab-brief">
                    <ul class="layui-tab-title" id="status">
                        {[range $menu := .submenu]}
                            <li data-status="{[$menu.Number]}" {[if IsSubOrEq $.CurrentPath (print "/" $.admin_path "/" $menu.Link)]}class="layui-this"{[end]}><a href="/{[$.admin_path]}/{[$menu.Link]}">{[$menu.Name]}</a></li>
                        {[end]}
                    </ul>
                </div>


                <div class="layui-tab layui-tab-brief">
                    <ul class="layui-tab-title" id="status">
                        {[range $db_menu := .database_submenu]}
                            <li data-status="{[$db_menu.Number]}" {[if IsSubOrEq $.CurrentPath (print "/" $.admin_path "/" $db_menu.Link)]}class="layui-this"{[end]}><a href="/{[$.admin_path]}/{[$db_menu.Link]}">{[$db_menu.Name]}</a></li>
                        {[end]}
                    </ul>
                </div>

                <div id="list" style="margin-top: 10px;"></div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">

layui.config({base: '/static/layuiadmin/'}).use(['table','jquery'], function(){
///
var admin = layui.admin
,$ = layui.$
,form = layui.form
,table = layui.table;


table.render({
    elem: '#list',
    url: '/{[.admin_path]}/system/database/list',
    title: '数据表',
    cols: [[
        {field:'table_name', title:'数据表名'},
        {field:'size', title:'占用空间', toolbar:"#sizeTpl"},
        {field:'type', title:'用途'},
        {title:'操作', toolbar: '#cmdTpl', width:120, fixed: 'right'}
     ]],
    page: false
});

///
});
</script>



<script type="text/html" id="sizeTpl">
{{d.size}}MB
</script>


<script type="text/html" id="cmdTpl">
{{# if (d.actions.indexOf('delete') > -1) { }}
<a class="layui-btn layui-btn-danger layui-btn-xs" lay-event='delete' onclick="Admin.tableNameDel(this, 'delete','{{d.table_name}}')">删除</a>
{{# } }}
{{# if (d.actions.indexOf('clean') > -1) { }}
<a class="layui-btn layui-btn-warm layui-btn-xs" lay-event='clean' onclick="Admin.tableNameClean(this, 'clean','{{d.table_name}}')">清空</a>
{{# } }}
</script>


{[template "backend/common/footer.tmpl" .]}