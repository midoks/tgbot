{[template "backend/common/header_nonav.tmpl" .]}

<div class="layui-fluid">
    <div class="layui-col-md12" style="padding: 5px;">
        <div class="layui-card">
            <div class="layui-card-body">
                                
                <div class="layui-tab layui-tab-brief">
                    <ul class="layui-tab-title" id="status">
                        {[range $menu := .submenu]}
                            <li data-status="{[$menu.Number]}" {[if eq (print "/" $.admin_path "/" $menu.Link) $.CurrentPath]}class="layui-this"{[end]}><a href="/{[$.admin_path]}/{[$menu.Link]}">{[$menu.Name]}</a></li>
                        {[end]}
                    </ul>
                </div>


                <div class="layui-tab layui-tab-brief">
                    <ul class="layui-tab-title" id="status">
                        <li data-status="1" class="layui-this">数据库节点列表</li>
                        <li data-status="2"><a onclick="Admin.open('添加节点','/{[$.admin_path]}/system/db/add',700,630)">添加数据库节点</a></li>
                    </ul>
                </div>

                <div id="list" style="padding-top: 5px;"></div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">

layui.config({base: '/static/layuiadmin/'}).use(['table','jquery'], function(){
///
var admin = layui.admin
,$ = layui.$
,form = layui.form
,table = layui.table;

table.render({
    elem: '#list',
    url: '/{[.admin_path]}/system/db/list',
    title: '数据表',
    cols: [[
        {field:'name', title:'节点名称'},
        {field:'host', title:'连接地址', toolbar:"#hostTpl"},
        {field:'dbname', title:'数据库名'},
        {field:'dbname', title:'数据库版本'},
        {field:'dbname', title:'用量'},
        {field:'status', title:'状态', toolbar:"#statusTpl"},
        {title:'操作', toolbar: '#cmdTpl', width:120, fixed: 'right'}
     ]],
    page: true
});

///
});
</script>

<script type="text/html" id="statusTpl">
{{# if (d.status == 1){ }}
<a class="layui-btn layui-btn-xs layui-btn-normal" lay-event="status">已启用</a>
{{# } else if (d.status == 0) { }}
<a class="layui-btn layui-btn-xs layui-btn-danger" lay-event="status">已暂停</a>
{{# } }}
</script>

<script type="text/html" id="hostTpl">{{d.host}}:{{d.port}}</script>

<script type="text/html" id="cmdTpl">
<a class="layui-btn layui-btn-xs" href="/{[.admin_path]}/system/db/details?id={{d.id}}">详情</a>
<a class="layui-btn layui-btn-danger layui-btn-xs" lay-event='delete' onclick="Admin.del(this, 'delete','{{d.id}}')">删除</a>
</script>

{[template "backend/common/footer.tmpl" .]}