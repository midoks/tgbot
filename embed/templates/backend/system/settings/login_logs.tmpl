{[template "backend/common/header_nonav.tmpl" .]}

<div class="layui-fluid">
    <div class="layui-col-md12" style="padding: 5px;">
        <div class="layui-card">
            <div class="layui-card-body">

                <div class="layui-tab layui-tab-brief">
                    <ul class="layui-tab-title" id="status">
                        {[range $menu := .submenu]}
                            <li data-status="{[$menu.Number]}" {[if IsSubOrEq $.CurrentPath (print "/" $.admin_path "/" $menu.Link)]}class="layui-this"{[end]}><a href="/{[$.admin_path]}/{[$menu.Link]}">{[$menu.Name]}</a></li>
                        {[end]}
                    </ul>
                </div>

                <div class="layui-tab layui-tab-brief">
                    <ul class="layui-tab-title" id="status">
                        <li data-status="1"><a href="/{[$.admin_path]}/system/settings/login">设置</a></li>
                        <li data-status="2" class="layui-this">登录历史</li>
                    </ul>
                </div>

                <div class="no-thead">
                    <div id="list"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">

layui.config({base: '/static/layuiadmin/'}).use(['table','jquery'], function(){
///
var admin = layui.admin
,$ = layui.$
,form = layui.form
,table = layui.table;

table.render({
    elem: '#list',
    url: '/{[.admin_path]}/system/settings/login/logs/list?admin_id={[$.login_uid]}',
    title: '数据表',
    cols: [[
        {field:'ip', title:'IP'},
        {field:'user_agent', title:'UA'},
        {field:'create_time', title:'时间'},
     ]],
    page: true
    ,done: function(){
        $('.no-thead .layui-table-view .layui-table-header').css('display','none');
    }
});

///
});
</script>

<style>
.no-thead .layui-table-view .layui-table-header{display:none;}
</style>

{[template "backend/common/footer.tmpl" .]}
