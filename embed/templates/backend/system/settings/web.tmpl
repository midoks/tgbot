{[template "backend/common/header_nonav.tmpl" .]}

<div class="layui-fluid">
    <div class="layui-col-md12" style="padding: 5px;">
        <div class="layui-card">
            <div class="layui-card-body">
                {[template "backend/system/part_settings_menu.tmpl" .]}
                
                <div class="layui-form toolbar" style="margin-top: 10px;margin-bottom: 10px;">
                <form class="layui-form layui-form-pane" onclick="return false;">
                    <table class="layui-table">
                        <colgroup><col width="150"><col></colgroup>
                        <tbody>
                            <tr>
                                <td>站点名称 *</td>
                                <td>
                                    <div class="layui-input-inline">
                                        <input type="text" name="name" autocomplete="off" class="layui-input" value="{[if .setting_web_ui]}{[.setting_web_ui.GetWebUIValue.Name]}{[end]}" placeholder="">
                                    </div>
                                    <p class="layui-font-12 pt5"></p>
                                </td>
                            </tr>

                            <tr>
                                <td>副标题 *</td>
                                <td>
                                    <div class="layui-input-inline">
                                        <input type="text" name="subtitle" autocomplete="off" class="layui-input" value="{[if .setting_web_ui]}{[.setting_web_ui.GetWebUIValue.Subtitle]}{[end]}" placeholder="">
                                    </div>
                                    <p class="layui-font-12 pt5"></p>
                                </td>
                            </tr>

                            <tr>
                                <td colspan="2" >
                                    <button class="layui-btn" lay-filter="setting_web_ui" lay-submit>保存</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">

layui.config({base: '/static/layuiadmin/'}).use(['table','jquery'], function(){
///
var admin = layui.admin
,$ = layui.$
,form = layui.form
,table = layui.table;

form.on("submit(setting_web_ui)", function(data){
    var field = data.field;
    $.post("/{[$.admin_path]}/system/settings/web", field, function(res) {
        // console.log(res);
        showMsg(res.msg, function(){
            if(res.code > -1){
                parent.location.reload();
            }
        },{icon: res.code > -1 ? 1 : 2,shift:res.code>-1 ? 0 : 6});
    },'json');
    return false;
});


///
});
</script>

{[template "backend/common/footer.tmpl" .]}