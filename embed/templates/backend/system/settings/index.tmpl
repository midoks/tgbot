{[template "backend/common/header_nonav.tmpl" .]}

<div class="layui-fluid">
    <div class="layui-col-md12" style="padding: 5px;">
        <div class="layui-card">
            <div class="layui-card-body">

                <div class="layui-tab layui-tab-brief">
                    <ul class="layui-tab-title" id="status">
                        {[range $menu := .submenu]}
                            <li data-status="{[$menu.Number]}" {[if eq (print "/" $.admin_path "/" $menu.Link) $.CurrentPath]}class="layui-this"{[end]}><a href="/{[$.admin_path]}/{[$menu.Link]}">{[$menu.Name]}</a></li>
                        {[end]}
                    </ul>
                </div>
                
                <div class="layui-form toolbar" style="margin-top: 10px;margin-bottom: 10px;">
                <form class="layui-form layui-form-pane" onclick="return false;">
                    <table class="layui-table">
                        <colgroup><col width="150"><col></colgroup>
                        <tbody>
                            <tr>
                                <td>本机地址 *</td>
                                <td>
                                    <div class="layui-input-inline">
                                        <input type="text" name="domain_name" autocomplete="off" class="layui-input" value="{[if .setting_admin_ui]}{[.setting_admin_ui.GetAdminUIValue.DomainName]}{[end]}" placeholder="">
                                    </div>
                                    <p class="layui-font-12 pt5">和发送消息有关系。</p>
                                </td>
                            </tr>

                            <tr>
                                <td>产品名称 *</td>
                                <td>
                                    <div class="layui-input-inline">
                                        <input type="text" name="product_name" autocomplete="off" class="layui-input" value="{[if .setting_admin_ui]}{[.setting_admin_ui.GetAdminUIValue.ProductName]}{[end]}" placeholder="">
                                    </div>
                                    <p class="layui-font-12 pt5">简短的产品名称，可以使用变量${product.name}在网页里展示此名称，建议仅包含英文和数字字符。</p>
                                </td>
                            </tr>

                            <tr>
                                <td>管理员系统名称 *</td>
                                <td>
                                    <div class="layui-input-inline">
                                        <input type="text" name="system_name" autocomplete="off" class="layui-input" value="{[if .setting_admin_ui]}{[.setting_admin_ui.GetAdminUIValue.SystemName]}{[end]}" placeholder="">
                                    </div>
                                    <p class="layui-font-12 pt5">当前管理系统界面上显示的名称。</p>
                                </td>
                            </tr>

                            <tr>
                                <td colspan="2" >
                                    <button class="layui-btn" lay-filter="setting_admin_ui" lay-submit>保存</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">

layui.config({base: '/static/layuiadmin/'}).use(['table','jquery'], function(){
///
var admin = layui.admin
,$ = layui.$
,form = layui.form
,table = layui.table;

form.on("submit(setting_admin_ui)", function(data){
    var field = data.field;
    $.post("/{[$.admin_path]}/system/settings/home", field, function(res) {
        showMsg(res.msg, function(){
            if(res.code > -1){
                parent.location.reload();
            }
        },{icon: res.code > -1 ? 1 : 2,shift:res.code>-1 ? 0 : 6});
    },'json');
    return false;
});


///
});
</script>

{[template "backend/common/footer.tmpl" .]}