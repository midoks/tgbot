{[template "backend/common/header_nonav.tmpl" .]}

<div class="layui-fluid">
    <div class="layui-col-md12" style="padding: 5px;">
        <div class="layui-card">
            <div class="layui-card-body">

                <div class="layui-tab layui-tab-brief">
                    <ul class="layui-tab-title" id="status">
                        {[range $menu := .submenu]}
                            <li data-status="{[$menu.Number]}" {[if eq (print "/" $.admin_path "/" $menu.Link) $.CurrentPath]}class="layui-this"{[end]}><a href="/{[$.admin_path]}/{[$menu.Link]}">{[$menu.Name]}</a></li>
                        {[end]}
                    </ul>
                </div>

                <div class="layui-tab layui-tab-brief">
                    <ul class="layui-tab-title" id="status">
                        <li data-status="1" class="layui-this">设置</li>
                        <li data-status="2"><a href="/{[$.admin_path]}/system/settings/login/logs">登录历史</a></li>
                    </ul>
                </div>
                
                <div class="layui-form toolbar" style="margin-top: 10px;margin-bottom: 10px;">
                <form class="layui-form layui-form-pane" onclick="return false;">
                    <table class="layui-table">
                        <colgroup><col width="150"><col></colgroup>
                        <tbody>
                            <tr>
                                <td>登录用户名 *</td>
                                <td>
                                    <div class="layui-input-inline">
                                        <input type="text" name="name" autocomplete="off" class="layui-input" value="{[if .login_name]}{[.login_name]}{[end]}" placeholder="">
                                    </div>
                                    <p class="layui-font-12 pt5">只能含有英文、数字或下划线。</p>
                                </td>
                            </tr>

                            <tr>
                                <td>登录密码 *</td>
                                <td>
                                    <div class="layui-input-inline">
                                        <input type="password" name="password" autocomplete="off" class="layui-input" value="" placeholder="">
                                    </div>
                                    <p class="layui-font-12 pt5">不填表示保留原有密码。</p>
                                </td>
                            </tr>

                            <tr>
                                <td>确认密码 *</td>
                                <td>
                                    <div class="layui-input-inline">
                                        <input type="password" name="password2" autocomplete="off" class="layui-input" value="" placeholder="">
                                    </div>
                                    <p class="layui-font-12 pt5">不填表示保留原有密码。</p>
                                </td>
                            </tr>

                            <tr>
                                <td colspan="2">
                                    <button class="layui-btn" lay-filter="submit_log" lay-submit>保存</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">

layui.config({base: '/static/layuiadmin/'}).use(['table','jquery'], function(){
///
var admin = layui.admin
,$ = layui.$
,form = layui.form
,table = layui.table;

form.on("submit(submit_log)", function(data){
    var field = data.field;
    $.post("/{[$.admin_path]}/system/settings/login", field, function(res) {
        showMsg(res.msg, function(){
            layer.close(index);
            if(res.code > -1){
                parent.location.reload();
            }
        },{icon: res.code > -1 ? 1 : 2,shift:res.code>-1 ? 0 : 6});
    },'json');
    return false;
});

///
});
</script>

{[template "backend/common/footer.tmpl" .]}