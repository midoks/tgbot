<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>{[if .setting_admin_ui]}{[.setting_admin_ui.GetAdminUIValue.SystemName]}{[else]}uptimepk{[end]}</title>
    <meta name="renderer" content="webkit">
    <meta http-equiv="X-UA-Compatible" content="IE=edge,chrome=1">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, minimum-scale=1.0, maximum-scale=1.0, user-scalable=0">
    <link rel="stylesheet" href="/static/layuiadmin/layui/css/layui.css?v={[.version]}" media="all">
    <link rel="stylesheet" href="/static/layuiadmin/style/admin.css?v={[.version]}" media="all">
    <link rel="stylesheet" href="/static/layuiadmin/style/login.css?v={[.version]}" media="all">
</head>
<body>

<div class="layadmin-user-login layadmin-user-display-show" id="LAY-user-login" style="display: none;">

    <div class="layadmin-user-login-main">
        <div class="layadmin-user-login-box layadmin-user-login-header">
            <h2>{[if .setting_admin_ui]}{[.setting_admin_ui.GetAdminUIValue.SystemName]}{[else]}监控管理{[end]}</h2>
        </div>
        
        <div class="layadmin-user-login-box layadmin-user-login-body layui-form">
            <div class="layui-form-item">
                <label class="layadmin-user-login-icon layui-icon layui-icon-username" for="LAY-user-login-username"></label>
                <input type="text" name="username" id="LAY-user-login-username" lay-verify="required" placeholder="用户名" class="layui-input" autocomplete="off"/>
            </div>
            
            <div class="layui-form-item">
                <label class="layadmin-user-login-icon layui-icon layui-icon-password" for="LAY-user-login-password"></label>
                <input type="password" name="password" id="LAY-user-login-password" lay-verify="required" placeholder="密码" class="layui-input" autocomplete="off"/>
            </div>
            
        
            <div class="layui-form-item">
                <button id="login" class="layui-btn layui-btn-fluid" lay-submit lay-filter="login-submit">登 入</button>
            </div>

        </div>
    </div>
    
</div>

<script src="/static/layuiadmin/layui/layui.js?v={[BuildCommit]}"></script>  
<script>
layui.config({
    base: '/static/layuiadmin/'
}).extend({
    index: 'lib/index'
}).use(['index', 'user'], function(){
///
var $ = layui.$
,setter = layui.setter
,admin = layui.admin
,form = layui.form
,router = layui.router()
,search = router.search;

form.render();

$(document).keydown(function(event){
    if(event.keyCode == 13){
        $('#login').click();
        return false;
    }
});

//提交
form.on('submit(login-submit)', function(d){
    $.ajax({
        type: "POST",
        headers: {'Content-Type': 'application/json'},
        url: "/{[.admin_path]}/login",
        data: JSON.stringify(d.field),
        dataType: 'json',
        success: function(res) {
            console.log(res);
            if (res.code != 200 ){
                layer.msg(res.msg, {icon: 2});
            } else if (res.code == 200){
                layer.msg("登录成功", {icon: 1});
                setTimeout(function(){
                    location.href = "/{[.admin_path]}/index";
                }, 2000);
            } else {
                layer.msg("访问异常!", {icon: 2});
            }
        },
        error:function(e){
            layer.msg(e, {icon: 2});
        }
    });
});
///
});
</script>
</body>
</html>