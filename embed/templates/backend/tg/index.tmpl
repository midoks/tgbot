{[template "backend/common/header.tmpl" .]}

<div class="layui-fluid">
    <div class="layui-col-md12" style="padding: 5px;">
        <div class="layui-card">
            <div class="layui-card-body">

                <div class="layui-form toolbar" style="margin-top: 10px;margin-bottom: 10px;">
                <form class="layui-form" action="" id="monitor_form" onclick="return false;">

                    <button type="button" class="layui-btn layui-btn-sm" onclick="Admin.open('添加','/{[$.admin_path]}/tg/add',800,600)">
                        <i class="layui-icon layui-icon-add-circle"></i> 添加
                    </button>


                    <div class="layui-inline mr0">
                        <div class="layui-input-inline mr0">
                            <input type="text" name="key" placeholder="关键词" autocomplete="off" class="layui-input h30" value="">
                        </div>
                    </div>
                

                    <div class="layui-inline mr0">
                        <button class="layui-btn layui-btn-sm" id="table-sreach" data-id="list" lay-submit lay-filter="table-sreach"><i class="layui-icon">&#xe615;</i>搜索
                        </button>
                    </div>
                </form>
                </div>

                <div id="list"></div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">

layui.config({base: '/static/layuiadmin/'}).use(['table','jquery','layer'], function(){
///
var admin = layui.admin
,$ = layui.$
,form = layui.form
,table = layui.table
,layer = layui.layer;


function renderTable(){
    
    var where_data = $('#monitor_form').serializeArray();
    where_data = array2arr(where_data);

    table.render({
        elem: '#list',
        url: '/{[.admin_path]}/tg/list',
        title: '数据表',
        cols: [[
            {field:'name', title:'名称'},
            {field:'mark', title:'备注', toolbar:"#markTpl"},
            {field:'listen_enable', title:'监听', toolbar:"#listenenableTpl"},
            {field:'status', title:'状态', toolbar:"#statusTpl",width:80},
            {title:'操作', toolbar: '#cmdTpl', width:170, fixed: 'right'}
         ]],
        page: true,
        where:where_data,
        done: function(res, curr, count){
            $('#list').next('.layui-table-view').find('span.error-tip').on('mouseenter', function(){
                var errorMsg = $(this).attr('data-error');
                var hour = String($(this).attr('data-hour')).padStart(2, '0');
                var minute = String($(this).attr('data-minute')).padStart(2, '0');
                var msg = '错误: ' + errorMsg + ' | 时间: ' + hour + ':' + minute;
                layer.tips(msg, this, {tips: [1, '#FF5722']});
            }).on('mouseleave', function(){
                layer.closeAll('tips');
            });
            $('#list').next('.layui-table-view').find('span.speed-tip').on('mouseenter', function(){
                var speed = $(this).attr('data-speed');
                var sizeKB = (parseInt($(this).attr('data-size')) / 1024).toFixed(2) + ' KB';
                var hour = String($(this).attr('data-hour')).padStart(2, '0');
                var minute = String($(this).attr('data-minute')).padStart(2, '0');
                var msg = '耗时: ' + speed + 'ms | 大小: ' + sizeKB + ' | 时间: ' + hour + ':' + minute;
                layer.tips(msg, this, {tips: [1, '#5FB878']});
            }).on('mouseleave', function(){
                layer.closeAll('tips');
            });
        }
    });

}

renderTable();

// search
form.on('submit(table-sreach)', function(){
    renderTable();
    return false;
});



table.on('toolbar', function(obj){
    switch(obj.event){
    };
});

table.on('tool(list)', function(obj){
    switch(obj.event){
        case 'status':opStatus(obj);break;
    };
});

function opStatus(obj){
    $.post('/{[.admin_path]}/tg/trigger_status', {"id":obj.data.id}, function(data) {
        showMsg(data.msg,function(){
            if (data.code>-1){
                location.reload();
            }
        },{icon:data.code>-1?1:2});
    },'json');
}


///
});
</script>


<script type="text/html" id="runTpl">
{{# layui.each(d.log_list, function(i, item){ }}
{{# if(item.is_valid == 1){ }}
<span style="color:green;margin-right:2px;" data-speed="{{item.speed}}" data-size="{{item.size}}" data-hour="{{item.hour}}" data-minute="{{item.minute}}" class="speed-tip">●</span>
{{# } else if(item.is_valid == 0){ }}
<span style="color:red;margin-right:2px;" data-error="{{item.error_msg}}" data-hour="{{item.hour}}" data-minute="{{item.minute}}" class="error-tip">●</span>
{{# } }}
{{# }); }}
</script>


