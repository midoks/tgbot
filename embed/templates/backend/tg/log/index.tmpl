{[template "backend/common/header.tmpl" .]}


<div class="layui-fluid">
    <div class="layui-col-md12" style="padding: 5px;">
        <div class="layui-card">
            <div class="layui-card-body">

                <div class="layui-form toolbar" style="margin-top: 10px;margin-bottom: 10px;">
                <form class="layui-form" action="" id="tgbot_log_form" onclick="return false;">

                    <div class="layui-inline mr0">
                        <div class="layui-input-inline mr0">
                            <input name="times" id="date_range" class="layui-input date-icon h30" type="text" placeholder="请选择日期范围" autocomplete="off">
                        </div>
                    </div>

                    <div class="layui-inline mr0">
                        <div class="layui-input-inline h30">
                            <select name="type" id="type" class="layui-input h30">
                                <option value="">查询</option>
                                <option value="bot_id">机器人ID</option>
                                <option value="chat_id">聊天ID</option>
                                <option value="chat_name">聊天名称</option>
                                <option value="from_user_name">发送者</option>
                                <option value="message_type">消息类型</option>
                                <option value="content">内容</option>
                            </select>
                        </div>
                    </div>

                    <div class="layui-inline mr0">
                        <div class="layui-input-inline mr0">
                            <input type="text" name="key" placeholder="关键词" autocomplete="off" class="layui-input h30" value="">
                        </div>
                    </div>


                    <div class="layui-inline mr0">
                        <button class="layui-btn layui-btn-sm" id="table-sreach" data-id="list" lay-submit lay-filter="table-sreach"><i class="layui-icon">&#xe615;</i>搜索
                        </button>
                    </div>
                </form>
                </div>

                <div id="list"></div>
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">

layui.config({base: '/static/layuiadmin/'}).use(['table','jquery','layer'], function(){
///
var admin = layui.admin
,$ = layui.$
,form = layui.form
,table = layui.table
,layer = layui.layer;

var tableIns, tableData = [];

function renderTable(){
    // 获取表单参数
    var where_data = $('#tgbot_log_form').serializeArray();
    where_data = array2arr(where_data);

    tableIns = table.render({
        elem: '#list',
        url: '/{[.admin_path]}/tg/log/list',
        where: where_data,
        title: '消息日志',
        cols: [[
            {field:'id', title:'ID', width:80},
            {field:'bot_id', title:'机器人ID', width:120},
            {field:'chat_id', title:'聊天ID', width:140},
            {field:'chat_name', title:'聊天名称', width:150},
            {field:'chat_type', title:'聊天类型', width:120},
            {field:'user_id', title:'发送者ID', width:120},
            {field:'from_user_name', title:'发送者', width:120},
            {field:'message_type', title:'消息类型', width:120},
            {field:'content', title:'消息内容', width:300},
            {field:'level', title:'日志级别', width:120},
            {field:'op', title:'操作', width:120,toolbar:"#opTpl"},
            {field:'create_time', title:'创建时间', width:185, templet: function(d){return layui.util.toDateString(d.create_time * 1000, 'yyyy-MM-dd HH:mm:ss');}},
            {title:'操作', toolbar: '#cmdTpl', width:70, fixed: 'right'}
        ]],
        page: true,
        done: function(res, curr, count){
            // 表格渲染完成后的回调
        }
    });

}

renderTable();

// search
form.on('submit(table-sreach)', function(){
    renderTable();
    return false;
});
///
});
</script>

<script type="text/html" id="opTpl">
{{# if (d.op == 1){ }}
<a class="layui-btn layui-btn-xs layui-btn-danger" lay-event="op">删除</a>
{{# } else if (d.op == 2){ }}
<a class="layui-btn layui-btn-xs layui-btn-warm" lay-event="op">已封禁</a>
{{# } else { }}
<a class="layui-btn layui-btn-xs layui-btn-normal" lay-event="op">正常</a>
{{# } }}
</script>

<script type="text/html" id="cmdTpl">
<a class="layui-btn layui-btn-danger layui-btn-xs" lay-event='delete' onclick="Admin.del(this, '/{[$.admin_path]}/tg/log/delete','{{d.id}}','{{d.bot_id}}')">删除</a>
</script>

{[template "backend/common/footer.tmpl" .]}