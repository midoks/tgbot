{[template "backend/common/header_head.tmpl" .]}


<style type="text/css">
.layui-form-item .layui-input-inline{
    width: auto;
    margin-left: 5px;
}
.type-input{
    height:70px;
    overflow-y: auto;
}
.type-input::-webkit-scrollbar {
    width : 10px;
    height: 1px;
}
.type-input::-webkit-scrollbar-thumb {
    border-radius: 10px;
    box-shadow   : inset 0 0 5px rgba(0, 0, 0, 0.2);
    background   : #666;
}
.type-input::-webkit-scrollbar-track {
    box-shadow   : inset 0 0 5px rgba(0, 0, 0, 0.2);
    border-radius: 10px;
    background   : #ededed;
}
.layui-form-radio{
    margin: 0; 
    padding-right: 0;
}

.layui-form-pane .layui-form-checkbox {
    margin: 4px 0 4px 1px;
}
.layui-form-checkbox[lay-skin=primary] span {
    padding-right: 4px;
}
.layui-form-checkbox[lay-skin=primary] i {
    left: 6px;
}
.layui-form-item .layui-col-xs12{
    margin-top: 10px;
}
@media screen and (max-width: 990px){
    .layui-form-item .layui-col-xs12:first-child{
        margin-top: 0px;
    }
    .layui-form-item{
        margin-bottom: 10px; 
    }
}

.hide{
    display: none;
}

/* 菜单预览样式 */
.menu-preview {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 20px;
    color: white;
}

.menu-preview h3 {
    margin-bottom: 15px;
    font-size: 16px;
    font-weight: bold;
}

.menu-item {
    background: rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    padding: 12px 16px;
    margin-bottom: 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    transition: all 0.3s ease;
}

.menu-item:hover {
    background: rgba(255, 255, 255, 0.3);
    transform: translateX(5px);
}

.menu-item:last-child {
    margin-bottom: 0;
}

.menu-item .menu-text {
    flex: 1;
    font-size: 14px;
}

.menu-item .menu-arrow {
    font-size: 18px;
}
</style>
<!-- start -->

<div class="layui-fluid">
    <!-- 菜单预览区域 -->
    <div class="menu-preview">
        <h3>📋 菜单预览</h3>
        <div id="menu-preview-list">
            {[if .Data]}
            <div class="menu-item">
                <span class="menu-text">{[.Data.Name]}</span>
                <span class="menu-arrow">›</span>
            </div>
            {[else]}
            <div class="menu-item" style="opacity: 0.6;">
                <span class="menu-text">添加菜单后预览</span>
                <span class="menu-arrow">›</span>
            </div>
            {[end]}
        </div>
    </div>

    <div class="layui-form toolbar layui-padding-3" style="margin-top: 10px;margin-bottom: 10px;">
    <form class="layui-form layui-form-pane" onclick="return false;">
        <table class="layui-table">
            <colgroup><col width="150"><col></colgroup>
            <tbody>
                <tr>
                    <td>菜单名称</td>
                    <td>
                        <div class="layui-input-inline">
                            <input type="text" name="name" autocomplete="off" class="layui-input menu-name-input" value="{[if .Data]}{[.Data.Name]}{[end]}" placeholder="请输入菜单名称">
                        </div>
                    </td>
                </tr>

                <tr>
                    <td>菜单内容</td>
                    <td>
                        <div class="layui-input-inline" style="width: 400px;">
                            <textarea name="params" class="layui-textarea type-input menu-params-input" placeholder="请输入菜单内容，支持换行">{[if .Data]}{[.Data.Params]}{[end]}</textarea>
                        </div>
                    </td>
                </tr>

                <tr>
                    <td colspan="2">
                        <a class="table_more mlink" target_class="more_table">
                            <cite>更多选项</cite>
                            <i class="layui-icon layui-icon-down layui-nav-more"></i>
                        </a>
                    </td>
                </tr>

                <tr class="more_table hide">
                    <td>启用状态</td>
                    <td>
                        <input type="checkbox" name="status" lay-skin="primary" title="启用"
                        {[if $.Data]}{[if $.Data.Status]}checked{[end]}
                        {[else]}checked
                        {[end]}> 
                    </td>
                </tr>
                
            </tbody>
        </table>


        <div class="layui-form-item" style="text-align: center;">
            <input type="hidden" name="id" value="{[if $.Data]}{[$.Data.ID]}{[end]}">
            <button class="layui-btn" lay-filter="submit_tg" lay-submit>保存菜单</button>
        </div>
    </form>
    </div>

</div>


<script type="text/javascript">

layui.config({base: '/static/layuiadmin/'}).use(['table','jquery'], function(){
///
var admin = layui.admin
,$ = layui.$
,form = layui.form
,table = layui.table;

// 实时预览菜单名称
$('.menu-name-input').on('input', function() {
    var name = $(this).val();
    if (name) {
        $('#menu-preview-list .menu-item .menu-text').text(name);
        $('#menu-preview-list .menu-item').css('opacity', '1');
    } else {
        $('#menu-preview-list .menu-item .menu-text').text('添加菜单后预览');
        $('#menu-preview-list .menu-item').css('opacity', '0.6');
    }
});

form.on("submit(submit_tg)", function(data){
    var index = layer.load();
    var field = data.field;

    if (field['status'] == "on"){
        field['status'] = 1;
    } else {
        field['status'] = 0;
    }

    $.post("/{[$.admin_path]}/tg/pushmenu/add", field, function(res) {
        showMsg(res.msg, function(){
            layer.close(index);
            if(res.code > -1){
                parent.location.reload();
            }
        },{icon: res.code > -1 ? 1 : 2,shift:res.code>-1 ? 0 : 6});
    },'json');
    return false;
});


///
});
</script>

{[template "backend/common/footer.tmpl" .]}
