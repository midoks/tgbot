        $('#button-groups').html(html);
        updatePreview();
    }

    // 保存菜单
    window.saveMenu = function() {
        var message = $('#message-input').val();
        var keyboard = [];
        
        $('.button-row').each(function() {
            var row = [];
            var inputs = $(this).find('.btn-input');
            var urls = $(this).find('.btn-url');
            
            inputs.each(function(index) {
                var text = $(this).val().trim();
                var url = urls.eq(index).val().trim();
                if (text && url) {
                    row.push({
                        text: text,
                        url: url
                    });
                }
            });
            
            if (row.length > 0) {
                keyboard.push(row);
            }
        });
        
        var data = {
            name: 'Telegram 菜单',
            params: JSON.stringify({
                message: message,
                keyboard: keyboard
            }),
            status: 1
        };
        
        $.post("/{[$.admin_path]}/tg/pushmenu/add", data, function(res) {
            showMsg(res.msg, function(){
                if(res.code > -1){
                    layer.msg('菜单保存成功！', {icon: 1});
                }
            },{icon: res.code > -1 ? 1 : 2,shift:res.code>-1 ? 0 : 6});
        }, 'json');
    }
});
</script>

