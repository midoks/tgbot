<script type="text/javascript">
layui.config({base: '/static/layuiadmin/'}).use(['jquery'], function(){
    var $ = layui.$;

    // 初始化拖动排序
    $('#button-groups').sortable({
        handle: '.drag-handle',
        placeholder: 'ui-sortable-placeholder',
        tolerance: 'pointer',
        cursor: 'move',
        axis: 'y',
        update: function(event, ui) {
            updatePreview();
        }
    });

    // 初始化预览
    updatePreview();

    // 监听消息输入变化
    $('#message-input').on('input', function() {
        updatePreview();
    });

    // 监听按钮输入变化
    $(document).on('input', '.btn-input, .btn-url', function() {
        updatePreview();
    });

    // 更新预览
    function updatePreview() {
        // 更新消息预览
        var message = $('#message-input').val();
        $('#preview-message').text(message);
        
        // 更新键盘预览
        var rows = $('.button-row');
        var html = '';
        
        rows.each(function() {
            var inputs = $(this).find('.btn-input');
            var urls = $(this).find('.btn-url');
            var hasContent = false;
            
            var rowHtml = '<div class="keyboard-row">';
            inputs.each(function(index) {
                var text = $(this).val();
                var url = urls.eq(index).val();
                if (text) {
                    hasContent = true;
                    rowHtml += `<button class="keyboard-btn" onclick="openUrl('${url}')">${text}</button>`;
                }
            });
            rowHtml += '</div>';
            
            if (hasContent) {
                html += rowHtml;
            }
        });
        
        $('#keyboard-preview').html(html);
    }

    // 打开链接
    window.openUrl = function(url) {
        if (url && url != 'tg://user?id=' && url != 'tg://user?id=5568699210') {
            window.open(url, '_blank');
        }
    }

    // 添加行
    window.addRow = function() {
        var html = `
            <div class="button-row">
                <div class="drag-handle" title="拖动排序">☰</div>
                <input type="text" class="btn-input" placeholder="按钮文字">
                <input type="text" class="btn-url" placeholder="URL 链接">
                <button class="del-col-btn" onclick="delCol(this)">×</button>
            </div>
        `;
        $('#button-groups').append(html);
        updatePreview();
    }

    // 添加列到最后一行
    window.addCol = function() {
        var rows = $('.button-row');
        if (rows.length > 0) {
            var lastRow = rows.last();
            var html = `
                <input type="text" class="btn-input" placeholder="按钮文字">
                <input type="text" class="btn-url" placeholder="URL 链接">
                <button class="del-col-btn" onclick="delCol(this)">×</button>
            `;
            lastRow.append(html);
            updatePreview();
        }
    }

    // 删除列
    window.delCol = function(el) {
        var row = $(el).closest('.button-row');
        var cols = row.find('.btn-input').length;
        if (cols > 1) {
            $(el).prev().remove(); // 删除URL输入框
            $(el).prev().remove(); // 删除文字输入框
            $(el).remove();        // 删除按钮
            updatePreview();
        }
    }

    // 删除最后一行
    window.delRow = function() {
        var rows = $('.button-row');
        if (rows.length > 1) {
            rows.last().remove();
            updatePreview();
        }
    }

    // 重置表单
    window.resetForm = function() {
        $('#message-input').val('由于在解决的问题的时候，不给信息，无法了解情况。以后不再群里回答技术问题。全部去论坛提问。在解决问题的过程中，可能需要面板信息，和 SSH 信息，如无法提供请不要提问。为了让群里都知晓。轮播一年！\n为了不打扰双方，私聊解决问题先转 1000U，否则无视!');
        
        var html = `
            <div class="button-row">
                <div class="drag-handle" title="拖动排序">☰</div>
                <input type="text" class="btn-input" placeholder="按钮文字" value="海内外实名 KYC-执照代付✅域名">
                <input type="text" class="btn-url" placeholder="URL 链接" value="https://t.me/kuadugongzuoshi">
                <button class="del-col-btn" onclick="delCol(this)">×</button>
            </div>
            <div class="button-row">
                <div class="drag-handle" title="拖动排序">☰</div>
                <input type="text" class="btn-input" placeholder="按钮文字" value="高价收一切流量 @caifutong555">
                <input type="text" class="btn-url" placeholder="URL 链接" value="https://t.me/caifutong555">
                <button class="del-col-btn" onclick="delCol(this)">×</button>
            </div>
            <div class="button-row">
                <div class="drag-handle" title="拖动排序">☰</div>
                <input type="text" class="btn-input" placeholder="按钮文字" value="18+ 资源采集">
                <input type="text" class="btn-url" placeholder="URL 链接" value="https://ckzy1.com">
                <button class="del-col-btn" onclick="delCol(this)">×</button>
            </div>
            <div class="button-row">
                <div class="drag-handle" title="拖动排序">☰</div>
                <input type="text" class="btn-input" placeholder="按钮文字" value="实名认证/过人脸🕵️‍♀️各种账号处理✅">
                <input type="text" class="btn-url" placeholder="URL 链接" value="https://t.me/niuniu234">
                <button class="del-col-btn" onclick="delCol(this)">×</button>
            </div>
            <div class="button-row">
                <div class="drag-handle" title="拖动排序">☰</div>
                <input type="text" class="btn-input" placeholder="按钮文字" value="官网">
