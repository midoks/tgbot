{[template "backend/common/header_nonav.tmpl" .]}

<div class="layui-fluid">


    <div class="layui-col-md12" style="padding: 5px;">
        <div class="layui-card">
            <div class="layui-card-body">

                <div style="display:flex;align-items:center;gap:8px;margin-bottom: 1rem;">
                    <a href="/{[.admin_path]}/admin/index" style="display:flex;align-items:center;">
                        <i class="layui-icon layui-icon-return"></i>  
                    </a>

                    <span style="margin:0;font-size:18px;">
                        {[if .Data]}{[.Data.FullName]} ({[.Data.Username]}){[end]}
                    </span>
                </div>

                <div class="layui-tab layui-tab-brief">
                    <ul class="layui-tab-title" id="status">
                        <li data-status="1" ><a href="/{[.admin_path]}/admin/details?id={[.id]}">概览</a></li>
                        <li data-status="2" class="layui-this">修改</li>
                        <li data-status="3"><a href="/{[.admin_path]}/admin/api?id={[.id]}">API</a></li>
                    </ul>
                </div>


                <div class="layui-form toolbar" style="margin-top: 10px;margin-bottom: 10px;">
                <form class="layui-form layui-form-pane" onclick="return false;">
                    <table class="layui-table">
                        <colgroup><col width="150"><col></colgroup>
                        <tbody>
                            <tr>
                                <td>全名 *</td>
                                <td>
                                    <div class="layui-input-inline">
                                        <input type="text" name="full_name" autocomplete="off" class="layui-input" value="{[if .Data]}{[.Data.FullName]}{[end]}" placeholder="">
                                    </div>
                                    <p class="layui-font-12 pt5">可以输入姓名、公司名等容易识别的名称。</p>
                                </td>
                            </tr>

                            <tr>
                                <td>登录用户名 *</td>
                                <td>
                                    <div class="layui-input-inline">
                                        <input type="text" name="username" autocomplete="off" class="layui-input" value="{[if .Data]}{[.Data.Username]}{[end]}" placeholder="">
                                    </div>
                                    <p class="layui-font-12 pt5">用户名只能英文、数字、下划线的组合。</p>
                                </td>
                            </tr>

                            <tr>
                                <td>登录密码</td>
                                <td>
                                    <input type="password" name="password" autocomplete="off" class="layui-input" value="" placeholder="登录密码">
                                </td>
                            </tr>

                            <tr>
                                <td>确认密码</td>
                                <td>
                                    <input type="password" name="password2" autocomplete="off" class="layui-input" value="" placeholder="确认登录密码">
                                </td>
                            </tr>

                            <tr>
                                <td>允许登录</td>
                                <td>
                                    <input type="checkbox" name="allow_login" lay-text="" {[if .Data]}{[if .Data.AllowLogin]}checked{[end]}{[end]}> 
                                    <p class="layui-font-12 pt5">选中后，当前管理员才可以登录当前的管理平台。</p>
                                </td>
                            </tr>

                            <tr>
                                <td>超级管理员</td>
                                <td>
                                    <input type="checkbox" name="super_admin" lay-filter="super_admin" {[if .Data]}{[if .Data.SuperAdmin]}checked{[end]}{[end]}> 
                                    <p class="layui-font-12 pt5">选中后，表示当前管理员为超级管理员；超级管理员自动拥有所有的管理权限。</p>
                                </td>
                            </tr>

                            <tr class="auth {[if .Data]}{[if .Data.SuperAdmin]}hide{[end]}{[end]}">
                                <td>权限</td>
                                <td>
                                    {[range $menu := .Menus]}
                                        {[if (index $.AuthMap $menu.Code)]}
                                            <input type="checkbox" name="auth[{[$menu.Code]}]" lay-text="{[$menu.Name]}" checked>
                                        {[else]}
                                            <input type="checkbox" name="auth[{[$menu.Code]}]" lay-text="{[$menu.Name]}">
                                        {[end]}
                                    {[end]}
                                </td>
                            </tr>

                            <tr>
                                <td>启用当前管理员</td>
                                <td>
                                    <input type="checkbox" name="status" lay-text="" {[if .Data]}{[if .Data.Status]}checked{[end]}{[end]}> 
                                </td>
                            </tr>

                            <tr>
                                <td colspan="2" >
                                    <input type="hidden" name="id" value="{[if .Data]}{[.Data.ID]}{[end]}">
                                    <button class="layui-btn" lay-filter="submit_admin" lay-submit>保存</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </form>
                </div>
                <!-- ... -->
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">
layui.config({base: '/static/layuiadmin/'}).use(['table','jquery'], function(){
///
var admin = layui.admin
,$ = layui.$
,form = layui.form
,table = layui.table;

form.on('checkbox(super_admin)', function(data){
    var checked = data.elem.checked;
    $('.auth').toggleClass('hide', checked);
});


form.on("submit(submit_admin)", function(data){
    var index = layer.load();
    var field = data.field;

    if (field['status'] == "on"){
        field['status'] = true;
    } else {
        field['status'] = false;
    }

    if (field['allow_login'] == "on"){
        field['allow_login'] = true;
    } else {
        field['allow_login'] = false;
    }

    if (field['super_admin'] == "on"){
        field['super_admin'] = true;
    } else {
        field['super_admin'] = false;
    }

    $.post("/{[$.admin_path]}/admin/add", field, function(res) {
        showMsg(res.msg, function(){
            layer.close(index);
            if(res.code > -1){
                parent.location.reload();
            }
        },{icon: res.code > -1 ? 1 : 2,shift:res.code>-1 ? 0 : 6});
    },'json');
    return false;
});

///
});
</script>

{[template "backend/common/footer.tmpl" .]}
