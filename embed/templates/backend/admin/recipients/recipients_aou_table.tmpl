<div class="layui-form toolbar" style="margin-top: 10px;margin-bottom: 10px;">
<form class="layui-form layui-form-pane" onclick="return false;">
    <table class="layui-table">
        <colgroup><col width="150"><col></colgroup>
        <tbody>
            <tr>
                <td>系统管理员 *</td>
                <td>
                    <div class="layui-input-inline">
                        <select name="admin_id" lay-verify="required">
                            <option value="">[选择系统管理员]</option>
                            {[range $admin_data := .AdminList]}
                                {[if eq $admin_data.ID $.AdminID]}
                                <option value="{[$admin_data.ID]}" selected>{[$admin_data.Username]}</option>
                                {[else]}
                                <option value="{[$admin_data.ID]}">{[$admin_data.Username]}</option>
                                {[end]}
                            {[end]}
                        </select>
                    </div>
                    <div>
                    <p class="layui-font-12">选择系统管理员。</p>
                </td>
            </tr>
            <tr>
                <td>通知媒介 *</td>
                <td>
                    <div class="layui-input-inline">
                        <select name="media_id" lay-verify="required">
                            <option value="">[选择通知媒介]</option>
                            {[range $recipients_data := .RecipientsList]}
                                {[if eq $recipients_data.ID $.MediaID]}
                                <option value="{[$recipients_data.ID]}" selected>{[$recipients_data.Name]}</option>
                                {[else]}
                                <option value="{[$recipients_data.ID]}">{[$recipients_data.Name]}</option>
                                {[end]}
                            {[end]}
                        </select>
                    </div>
                    <div>
                    <p class="layui-font-12">选择通知媒介。</p>
                </td>
            </tr>
            <tr>
                <td>接收人标识 *</td>
                <td>
                    <div class="layui-input-inline" style="width: 500px;">
                        <input type="text" name="recipient_id" value="{[.Data.RecipientID]}" placeholder="请输入接收人标识" autocomplete="off" class="layui-input">
                    </div>
                    <div>
                    <p class="layui-font-12">接收人标识，如：邮箱地址、手机号、Telegram ID 等。</p>
                </td>
            </tr>

            <tr>
                <td>分组</td>
                <td>
                    <div class="layui-input-inline">
                        <select name="group_id">
                            <option value="">[选择分组]</option>
                            <option value="0">暂无分组</option>
                            {[range $g := .GroupList]}
                                {[if eq $g.ID $.GroupID]}
                                <option value="{[$g.ID]}" selected>{[$g.Name]}</option>
                                {[else]}
                                <option value="{[$g.ID]}">{[$g.Name]}</option>
                                {[end]}
                            {[end]}
                        </select>
                    </div>
                    <div>
                </td>
            </tr>

            <tr>
                <td>汇总周期</td>
                <td>
                    <div>
                        <div class="layui-inline">
                            <div class="layui-input-inline">
                                <input style="width: 60px;" type="number" name="interval" autocomplete="off" class="layui-input" value="{[if $.Data]}{[if $.Data.Interval]}{[$.Data.Interval]}{[else]}60{[end]}{[else]}60{[end]}">
                            </div>
                            <div class="layui-input-inline">
                                <select name="interval_type" lay-verify="required">
                                    <option value="minute" {[if $.Data]}{[if eq $.Data.IntervalType "minute" ]}selected{[end]}{[end]}>分钟</option>
                                    <option value="hour" {[if $.Data]}{[if eq $.Data.IntervalType "hour" ]}selected{[end]}{[end]}>小时</option>
                                    <option value="day" {[if $.Data]}{[if eq $.Data.IntervalType "day" ]}selected{[end]}{[end]}>天</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <p class="layui-font-12">心跳间隔/检测频率</p>
                </td>
            </tr>
            
            <tr>
                <td>关联的监控分组</td>
                <td>
                    <div class="layui-row">
                    {[range $monitor := .MonitorList]}
                        <div class="layui-col-xs6 layui-col-sm6 layui-col-md6">
                            <input type="checkbox" name="related[{[$monitor.ID]}]" lay-text="{[$monitor.Name]}" 
                            {[range $rcr_data := $.RecipientsMonitorRelated]}
                                {[if eq $rcr_data.MonitorGid $monitor.ID]}checked{[end]}
                            {[end]}>
                        </div>
                    {[end]}
                    </div>
                </td>
            </tr>

            <!--  more  -->
            <tr>
                <td colspan="2">
                    <a class="table_more mlink" target_class="more_table">
                        <cite>更多选项</cite>
                        <i class="layui-icon layui-icon-down layui-nav-more"></i>
                    </a>
                </td>
            </tr>

            <tr class="more_table" style="display:none;">
                <td>状态</td>
                <td>
                    <input type="checkbox" name="status" lay-skin="switch" lay-text="开启|关闭" 
                        {[if .Data]}
                            {[if .Data.Status]}checked{[end]}
                        {[else]}checked{[end]}
                    >
                    <div>
                    <p class="layui-font-12">是否启用该接收人。</p>
                </td>
            </tr>

            <tr class="more_table" style="display:none;">
                <td>备注</td>
                <td>
                    <textarea name="mark" class="layui-textarea" style="min-height:100px;" placeholder="">{[if .Data]}{[.Data.Mark]}{[end]}</textarea>
                    <p class="layui-font-12">备注信息。</p>
                </td>
            </tr>

            <tr>
                <td colspan="2">
                    <input type="hidden" name="id" value="{[.id]}">
                    <button class="layui-btn" lay-filter="submit_recipients" lay-submit>保存</button>
                    <button type="reset" class="layui-btn layui-btn-primary">重置</button>
                </td>
            </tr>

        </tbody>
    </table>
</form>
</div>
