{[template "backend/common/header_nonav.tmpl" .]}

<div class="layui-fluid">


    <div class="layui-col-md12" style="padding: 5px;">
        <div class="layui-card">
            <div class="layui-card-body">

                <div style="display:flex;align-items:center;gap:8px;margin-bottom: 1rem;">
                    <a href="/{[.admin_path]}/admin/recipients/instances" style="display:flex;align-items:center;">
                        <i class="layui-icon layui-icon-return"></i>  
                    </a>

                    <span style="margin:0;font-size:18px;">
                        {[if .Data]}
                            {[if eq .Data.MediaType "telegram" ]}telegram机器人{[else]}{[if eq .Data.MediaType "email" ]}邮件{[else]}{[if eq .Data.MediaType "webhook" ]}Webhook{[end]}{[end]}{[end]}
                        {[end]}
                    </span>
                </div>

                <div class="layui-tab layui-tab-brief">
                    <ul class="layui-tab-title" id="status">
                        <li data-status="1" class="layui-this">概览</li>
                        <li data-status="2"><a href="/{[.admin_path]}/admin/recipients/instances/update?id={[.id]}">修改</a></li>
                        <li data-status="3"><a href="/{[.admin_path]}/admin/recipients/instances/test?id={[.id]}">测试</a></li>
                    </ul>
                </div>

                <div class="cluster-boards bls_hover" style="margin-top: 10px;">
                    <div class="layui-row layui-col-space10">
                        <div class="layui-col-xs12 layui-col-sm4 layui-col-md3">
                            <div class="ccc_hover">
                                <div style="color: rgb(100, 116, 139); font-size: 14px; margin-bottom: 6px;">媒介名称</div>
                                <div style="font-size: 12px; color: #333;">{[if .Data]}{[.Data.Name]}{[end]}</div>
                            </div>
                        </div>
                        <div class="layui-col-xs12 layui-col-sm4 layui-col-md3">
                            <div class="ccc_hover">
                                <div style="color: rgb(100, 116, 139); font-size: 14px; margin-bottom: 6px;">状态</div>
                                <div style="font-size: 12px;">
                                    {[if .Data]}
                                        {[if .Data.Status]}<span style="color:#16b777;">已启用</span>
                                        {[else]}<span style="color:#e2e2e2;">已停用</span>
                                        {[end]}
                                    {[end]}
                                </div>
                            </div>
                        </div>
                        <div class="layui-col-xs12 layui-col-sm4 layui-col-md3">
                            <div class="ccc_hover">
                                <div style="color: rgb(100, 116, 139); font-size: 14px; margin-bottom: 6px;">发送频率（次/分钟）</div>
                                <div style="font-size: 12px;">
                                    {[if .Data.GetRate]}{[.Data.GetRate.Count]}{[end]}次/{[if .Data.GetRate]}{[.Data.GetRate.Minutes]}{[end]}分钟
                                </div>
                            </div>
                        </div>
                        <div class="layui-col-xs12 layui-col-sm4 layui-col-md3">
                            <div class="ccc_hover">
                                <div style="color: rgb(100, 116, 139); font-size: 14px; margin-bottom: 6px;">忽略相似消息周期</div>
                                <div style="font-size: 12px;">{[if .Data]}{[.Data.HashLife]}{[end]}</div>
                            </div>
                        </div>
                        <div class="layui-col-xs12 layui-col-sm4 layui-col-md3">
                            <div class="ccc_hover">
                                <div style="color: rgb(100, 116, 139); font-size: 14px; margin-bottom: 6px;;">备注</div>
                                <div style="font-size: 12px;">
                                    {[if .Data]}{[if eq .Data.Mark "" ]}<span class="disabled">没有设置</span>{[else]}{[.Data.Mark]}{[end]}{[end]}
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="cluster-boards bls_hover" style="margin-top: 10px;">
                    <div class="layui-row layui-col-space10">
                        <div class="layui-col-xs12 layui-col-sm4 layui-col-md3">
                            <div class="ccc_hover">
                                <div style="color: rgb(100, 116, 139); font-size: 14px; margin-bottom: 6px;">媒介类型</div>
                                <div style="font-size: 13px; color: #333;">
                                    {[if .Data]}
                                        {[if eq .Data.MediaType "telegram" ]}Telegram机器人{[end]}
                                        {[if eq .Data.MediaType "email" ]}邮件{[end]}
                                        {[if eq .Data.MediaType "webhook" ]}WebHook{[end]}
                                    {[end]}
                                </div>
                            </div>
                        </div>

                        {[if .Data]}
                            {[if eq .Data.MediaType "telegram" ]}
                                <div class="layui-col-xs12 layui-col-sm4 layui-col-md3">
                                    <div class="ccc_hover">
                                        <div style="color: rgb(100, 116, 139); font-size: 14px; margin-bottom: 6px;">机器人Token</div>
                                        <div style="font-size: 12px; color: #333;">{[if .Data]}{[.Data.GetTelegramParams.Token]}{[end]}</div>
                                    </div>
                                </div>
                            {[end]}
                            {[if eq .Data.MediaType "email" ]}
                                <div class="layui-col-xs12 layui-col-sm4 layui-col-md3">
                                    <div class="ccc_hover">
                                        <div style="color: rgb(100, 116, 139); font-size: 14px; margin-bottom: 6px;">SMTP</div>
                                        <div style="font-size: 12px; color: #333;">{[if .Data.GetEmailParams]}{[.Data.GetEmailParams.Smtp]}{[end]}</div>
                                    </div>
                                </div>

                                <div class="layui-col-xs12 layui-col-sm4 layui-col-md3">
                                    <div class="ccc_hover">
                                        <div style="color: rgb(100, 116, 139); font-size: 14px; margin-bottom: 6px;">账号</div>
                                        <div style="font-size: 12px; color: #333;">{[if .Data.GetEmailParams]}{[.Data.GetEmailParams.Username]}{[end]}</div>
                                    </div>
                                </div>

                                <div class="layui-col-xs12 layui-col-sm4 layui-col-md3">
                                    <div class="ccc_hover">
                                        <div style="color: rgb(100, 116, 139); font-size: 14px; margin-bottom: 6px;">密码</div>
                                        <div style="font-size: 12px; color: #333;">***</div>
                                    </div>
                                </div>

                                <div class="layui-col-xs12 layui-col-sm4 layui-col-md3">
                                    <div class="ccc_hover">
                                        <div style="color: rgb(100, 116, 139); font-size: 14px; margin-bottom: 6px;">发送者Email</div>
                                        <div style="font-size: 12px; color: #333;">{[if .Data.GetEmailParams]}{[.Data.GetEmailParams.From]}{[end]}</div>
                                    </div>
                                </div>
                            {[end]}
                            {[if eq .Data.MediaType "webhook" ]}
                                <div class="layui-col-xs12 layui-col-sm4 layui-col-md3">
                                    <div class="ccc_hover">
                                        <div style="color: rgb(100, 116, 139); font-size: 14px; margin-bottom: 6px;">URL</div>
                                        <div style="font-size: 12px; color: #333;">{[if .Data.GetWebhookParams]}{[.Data.GetWebhookParams.Url]}{[end]}</div>
                                    </div>
                                </div>

                                <div class="layui-col-xs12 layui-col-sm4 layui-col-md3">
                                    <div class="ccc_hover">
                                        <div style="color: rgb(100, 116, 139); font-size: 14px; margin-bottom: 6px;">请求方法</div>
                                        <div style="font-size: 12px; color: #333;">
                                            {[if .Data.GetWebhookParams]}
                                                {[if eq .Data.GetWebhookParams.Method "post" ]}POST{[end]}
                                                {[if eq .Data.GetWebhookParams.Method "get" ]}GET{[end]}
                                            {[end]}
                                        </div>
                                    </div>
                                </div>
                            {[end]}
                        {[end]}

                    </div>
                </div>

                <!-- ... -->
            </div>
        </div>
    </div>
</div>

{[template "backend/common/footer.tmpl" .]}
