{[template "backend/common/header_nonav.tmpl" .]}

<div class="layui-fluid">
    <div class="layui-col-md12" style="padding: 5px;">
        <div class="layui-card">
            <div class="layui-card-body">

                <div class="layui-breadcrumb" style="margin-bottom: 15px;">
                    <a href="/{[.admin_path]}/">首页</a>
                    <a href="/{[.admin_path]}/admin/recipients">接收人</a>
                    <a><cite>{[if .Data]}
                        {[.Data.AdminName]} （{[.Data.MediaName]}）
                        {[end]}</cite></a>
                </div>


                <div style="display:flex;align-items:center;gap:8px;margin-bottom: 1rem;">
                    <a href="/{[.admin_path]}/admin/recipients/instances" style="display:flex;align-items:center;">
                        <i class="layui-icon layui-icon-return"></i>  
                    </a>

                    <span style="margin:0;font-size:18px;">
                        {[if .Data]}
                        {[.Data.AdminName]} （{[.Data.MediaName]}）
                        {[end]}
                    </span>
                </div>

                <div class="layui-tab layui-tab-brief">
                    <ul class="layui-tab-title" id="status">
                        <li data-status="1"><a href="/{[.admin_path]}/admin/recipients/recipients/details?id={[.id]}">概览</a></li>
                        <li data-status="2" class="layui-this">修改</li>
                        <li data-status="3"><a href="/{[.admin_path]}/admin/recipients/recipients/test?id={[.id]}">测试</a></li>
                    </ul>
                </div>

                
                {[template "backend/admin/recipients/recipients_aou_table.tmpl" .]}

            </div>
        </div>
    </div>
</div>

<script>
layui.use(['form', 'layer'], function(){
////
var form = layui.form;
var layer = layui.layer;

form.on('submit(submit_recipients)', function(data){
    var field = data.field;
    var index = layer.load(2);
    
    // 收集所有选中的 related_ids
    var selected = [];
    for (var k in field) {
        var m = k.match(/^related\[(\d+)\]$/);
        if (m) {
            if (field[k] === 'on') {
                selected.push(parseInt(m[1], 10));
            }
            delete field[k];
        }
    }
    field['related_ids'] = selected;

    if (field['status'] == "on"){
        field['status'] = 1;
    } else {
        field['status'] = 0;
    }

    $.ajax({
        url: "/{[$.admin_path]}/admin/recipients/add",
        type: "POST",
        data: field,
        traditional: true, // arrays -> related_ids=1&related_ids=2
        dataType: "json",
        success: function(res){
            showMsg(res.msg, function(){
                layer.close(index);
                if(res.code > -1){
                    parent.location.reload();
                }
            },{icon: res.code > -1 ? 1 : 2,shift:res.code>-1 ? 0 : 6});
        }
    });
    return false;
});
////
});
</script>

{[template "backend/common/footer.tmpl" .]}
