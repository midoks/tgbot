{[template "backend/common/header_nonav.tmpl" .]}

<div class="layui-fluid">
    <div class="layui-col-md12" style="padding: 5px;">
        <div class="layui-card">
            <div class="layui-card-body">

                <div style="display:flex;align-items:center;gap:8px;margin-bottom: 1rem;">
                    <a href="/{[.admin_path]}/admin/recipients/instances" style="display:flex;align-items:center;">
                        <i class="layui-icon layui-icon-return"></i>  
                    </a>

                    <span style="margin:0;font-size:18px;">
                        {[if .Data]}
                            {[if eq .Data.MediaType "telegram" ]}telegram机器人{[else]}{[if eq .Data.MediaType "email" ]}邮件{[else]}{[if eq .Data.MediaType "webhook" ]}Webhook{[end]}{[end]}{[end]}
                        {[end]}
                    </span>
                </div>


                <div class="layui-tab layui-tab-brief">
                    <ul class="layui-tab-title" id="status">
                        <li data-status="1"><a href="/{[.admin_path]}/admin/recipients/instances/details?id={[.id]}">概览</a></li>
                        <li data-status="2" class="layui-this">修改</li>
                        <li data-status="3"><a href="/{[.admin_path]}/admin/recipients/instances/test?id={[.id]}">测试</a></li>
                    </ul>
                </div>

                {[template "backend/admin/recipients/instances_aou_table.tmpl" .]}
            </div>
        </div>
    </div>
</div>

<script type="text/javascript">

layui.config({base: '/static/layuiadmin/'}).use(['table','jquery'], function(){
///
var admin = layui.admin
,$ = layui.$
,form = layui.form
,table = layui.table;

function initMedia(data){
    $('.id_telegram,.id_webhook,.id_email').hide();
    if (data === 'telegram') {
        $('.id_telegram').show();
    } else if (data === 'webhook') {
        $('.id_webhook').show();
    } else if (data === 'email') {
        $('.id_email').show();
    }
}

var data = $('select[name=media_type]').val();
initMedia(data);

form.on('select(media)', function(data){
    initMedia(data.value);
});


form.on("submit(submit_recipients)", function(data){
    var index = layer.load();
    var field = data.field;

    if (field['status'] == "on"){
        field['status'] = 1;
    } else {
        field['status'] = 0;
    }

    if (field['telegram_listen_enable'] == "on"){
        field['telegram_listen_enable'] = 1;
    } else {
        field['telegram_listen_enable'] = 0;
    }

    $.post("/{[$.admin_path]}/admin/recipients/instances/add", field, function(res) {
        showMsg(res.msg, function(){
            layer.close(index);
            if(res.code > -1){
                parent.location.reload();
            }
        },{icon: res.code > -1 ? 1 : 2,shift:res.code>-1 ? 0 : 6});
    },'json');
    return false;
});

///
});
</script>

{[template "backend/common/footer.tmpl" .]}
