{[template "install/header.tmpl" .]}


<style type="text/css">
.layui-table td, .layui-table th{text-align:left;}
.layui-table tbody tr.no{background-color:#f00;color:#fff;}
</style>
<div class="install-box">
    <fieldset class="layui-elem-field layui-field-title">
        <legend>数据库配置</legend>
    </fieldset>
    <!-- <form class="layui-form layui-form-pane" action="?step=2" method="post"> -->
    <form class="layui-form layui-form-pane" action="/install/step1" method="post">
        <div class="layui-form-item">
            <label class="layui-form-label">数据库类型</label>
            <div class="layui-input-inline w200">
                <select name="type" lay-filter="db_type">
                    <option value="sqlite3" selected="selected">SQLite3</option>
                    <option value="mysql">MySQL</option>
                </select>
            </div>
            <div class="layui-form-mid layui-word-aux">数据库类型，MySQL、SQLite3</div>
        </div>

        <div class="layui-form-item" id="dbpath" style="display: block;">
            <label class="layui-form-label">数据库路径</label>
            <div class="layui-input-inline w200">
                <input type="text" class="layui-input" name="dbpath" lay-verify="title" value="{[.dbpath]}">
            </div>
            <div class="layui-form-mid layui-word-aux">数据库文件路径</div>
        </div>

        <div class="layui-form-item" id="hostname" style="display: none;">
            <label class="layui-form-label">服务器地址</label>
            <div class="layui-input-inline w200">
                <input type="text" class="layui-input" name="hostname" lay-verify="title" value="{[.hostname]}">
            </div>
            <div class="layui-form-mid layui-word-aux">数据库服务器地址，一般为127.0.0.1</div>
        </div>
        <div class="layui-form-item" id="port" style="display: none;">
            <label class="layui-form-label">数据库端口</label>
            <div class="layui-input-inline w200">
                <input type="number" class="layui-input" name="hostport" lay-verify="title" value="{[.hostport]}">
            </div>
            <div class="layui-form-mid layui-word-aux">系统数据库端口，一般为3306</div>
        </div>
        <div class="layui-form-item" id="dbname" style="display: none;">
            <label class="layui-form-label">数据库名称</label>
            <div class="layui-input-inline w200">
                <input type="text" class="layui-input" name="dbname" lay-verify="title" value="{[.dbname]}">
            </div>
            <div class="layui-form-mid layui-word-aux">系统数据库名,必须包含字母</div>
        </div>

        <div class="layui-form-item" id="username" style="display: none;">
            <label class="layui-form-label">数据库账号</label>
            <div class="layui-input-inline w200">
                <input type="text" class="layui-input" name="username" lay-verify="title" value="{[.username]}">
            </div>
            <div class="layui-form-mid layui-word-aux">连接数据库的用户名</div>
        </div>

        <div class="layui-form-item" id="password" style="display: none;">
            <label class="layui-form-label">数据库密码</label>
            <div class="layui-input-inline w200">
                <input type="password" class="layui-input" name="password" lay-verify="title">
            </div>
            <div class="layui-form-mid layui-word-aux">连接数据库的密码</div>
        </div>

        <div class="layui-form-item" id="table_prefix" style="display: block;">
            <label class="layui-form-label">数据库前缀</label>
            <div class="layui-input-inline w200">
                <input type="text" class="layui-input" name="table_prefix" lay-verify="title" value="{[.table_prefix]}">
            </div>
            <div class="layui-form-mid layui-word-aux">建议使用默认,数据库前缀必须带_</div>
        </div>

        <div class="layui-form-item" id="cover_check" style="display: none;">
            <label class="layui-form-label">覆盖数据库</label>
            <div class="layui-input-inline w200">
                <input type="radio" name="cover" value="1" title="覆盖">
                <input type="radio" name="cover" value="0" title="不覆盖" checked>
            </div>
            <div class="layui-form-mid layui-word-aux">如需保留原有数据，请选择不覆盖</div>
        </div>
        <div class="layui-form-item" id="cover_check_btn" style="display: none;">
            <button type="submit" class="layui-btn fl" style="margin-left:120px;" lay-submit="" lay-filter="dbTest">测试数据库连接</button>
            <div class="layui-form-mid layui-word-aux" style="margin-left:10px;">请先点击 【测试数据连接】 再安装</div>
        </div>
    
        <fieldset class="layui-elem-field layui-field-title">
            <legend>其他设置</legend>
        </fieldset>
        <div class="layui-form-item">
            <label class="layui-form-label">管理员账号</label>
            <div class="layui-input-inline w200">
                <input type="text" class="layui-input" name="account" lay-verify="title" value="admin">
            </div>
            <div class="layui-form-mid layui-word-aux">管理员账号最少5位</div>
        </div>
        <div class="layui-form-item">
            <label class="layui-form-label">管理员密码</label>
            <div class="layui-input-inline w200">
                <input type="password" class="layui-input" name="pass" lay-verify="title">
            </div>
            <div class="layui-form-mid layui-word-aux">保证密码最少6位</div>
        </div>
        <div class="layui-form-item">
            <label class="layui-form-label">初始化数据</label>
            <div class="layui-input-inline w200" >
                <input type="radio" name="initdata" value="1" title="创建" checked="">
                <input type="radio" name="initdata" value="0" title="不创建" >
            </div>
            <div class="layui-form-mid layui-word-aux">是否创建基础分类数据</div>
        </div>
        <div class="step-btns">
            <a href="/install" class="layui-btn layui-btn-primary layui-btn-big fl">返回上一步</a>
            <button type="submit" class="layui-btn layui-btn-big layui-btn-normal fr" lay-submit="" lay-filter="install" >立即执行安装</button>
        </div>
    </form>
</div>

<script type="text/javascript">
var test=0;
layui.use(function(){
///
var $ = layui.$
,setter = layui.setter
,form = layui.form;

form.render();
form.on('select(db_type)', function(data){
    var elem = data.elem;
    var othis = data.othis;
    var db_type = data.value; // 获得被选中的值

    if (db_type === "sqlite3") {
        $('#hostname').hide();
        $('#port').hide();
        $('#dbname').hide();
        $('#username').hide();
        $('#password').hide();
        $('#dbtest').hide();


        $('#cover_check').hide();
        $('#cover_check_btn').hide();

        if (db_type === "sqlite3") {
            $('#dbpath').show().val('data/tgbot.db');
        }
        return;
    } else if(db_type === "mysql") {
        $('#dbpath').hide();
        $('#hostname').show();
        $('#port').show();
        $('#dbname').show();
        $('#username').show();
        $('#password').show();
        $('#dbtest').show();
        $('#table_prefix').show();

        $('#cover_check').show();
        $('#cover_check_btn').show();

    }
});

form.on('submit(dbTest)', function(form_data) {
    layer.msg("数据提交中...",{time:500000});
    $.ajax({
        type: "POST",
        url: "/install/dbtest",
        data: form_data.field,
        dataType:'json',
        success: function(res) {
            if(res.code==200){
                test=1;
            }
            layer.msg(res.msg);
        }
    });
    return false;
});


//安装提交
form.on('submit(install)', function(form_data){
    var db_type = $('select[lay-filter="db_type"]').val();
    if (db_type == 'mysql'){
        if(test==0){
            layer.msg("请先点击并通过测试数据连接!");
            return false;
        }
    }
    $.ajax({
        type: "POST",
        url: "/install/step1",
        data: form_data.field,
        dataType:'json',
        success: function(res) {
            showMsg(res.msg, function(){
                if (res.code == 200){
                    location.href = "/{[.admin_path]}/index"
                }
            }, {icon: res.code>0?1:2}, 3000);
        }
    });
    return false;
});

///
});
</script>

{[template "install/footer.tmpl" .]}