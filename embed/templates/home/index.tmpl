{[template "home/common/header.tmpl" .]}

<div class="stats-container">
    <h2>系统统计</h2>
    <table class="stats-table">
        <thead>
            <tr>
                <th>统计项</th>
                <th>数值</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Bot 数量</td>
                <td>{[.BotCount]}</td>
            </tr>
            <tr>
                <td>最近7日消息数</td>
                <td>{[.Last7DayCount]}</td>
            </tr>
            <tr>
                <td>今日消息数</td>
                <td>{[.TodayMsgCount]}</td>
            </tr>
            <tr>
                <td>今日删除数</td>
                <td>{[.TodayDeleteCount]}</td>
            </tr>
        </tbody>
    </table>
</div>

<style>
.stats-container {
    max-width: 600px;
    margin: 40px auto;
    padding: 20px;
    background: #fff;
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
}

.stats-container h2 {
    margin-bottom: 20px;
    font-size: 20px;
    color: #333;
    border-bottom: 2px solid #007bff;
    padding-bottom: 10px;
}

.stats-table {
    width: 100%;
    border-collapse: collapse;
}

.stats-table th,
.stats-table td {
    padding: 12px 15px;
    text-align: left;
    border-bottom: 1px solid #eee;
}

.stats-table th {
    background-color: #f8f9fa;
    font-weight: 600;
    color: #666;
}

.stats-table tbody tr:hover {
    background-color: #f5f5f5;
}

.stats-table td:last-child {
    font-weight: 600;
    color: #007bff;
}
</style>

{[template "home/common/footer.tmpl" .]}